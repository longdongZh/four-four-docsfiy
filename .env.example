# 服务端口配置
HOST_PORT=3000

# Docker 镜像元数据
MAINTAINER=four-four-docsfiy
DESCRIPTION=four-four-docsfiy

# 自动刷新配置（开发模式）
# 设置为 true 启用文件监听和自动刷新
AUTO_RELOAD=false

# Docsify 基础配置
DOCSIFY_NAME=four-four-docsfiy
DOCSIFY_VERSION=2.20.1
# 这里填写你的文档路径，或者仓库路径
DOCSIFY_BASE_PATH=docs
DOCSIFY_ROUTER_MODE=hash
DOCSIFY_SUB_MAX_LEVEL=5
DOCSIFY_SIDEBAR_DISPLAY_LEVEL=5

# GitHub 仓库地址（可选）
# DOCSIFY_REPO=https://github.com/your-repo/docs

# 百度统计 ID（可选）
BAIDU_TJ_ID=

# Valine 评论系统配置（可选）
VALINE_APP_ID=
VALINE_APP_KEY=

# 认证配置
AUTH_ENABLE=true
AUTH_PASSWORD=
